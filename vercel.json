{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/model", "destination": "/model.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pitch.jcamd.com" }],
      "destination": "https://pitch.dumbmodel.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "vector-pitch.vercel.app" }],
      "destination": "https://pitch.dumbmodel.com/:path*",
      "permanent": false
    }
  ]
}
